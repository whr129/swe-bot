# Discord Bot Token - get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token

# OpenAI API Key - for AI features
OPENAI_API_KEY=your_openai_api_key

# Optional: Override LeetCode API base (default uses leetcode-api-pied.vercel.app)
# LEETCODE_API_BASE=https://leetcode-api-pied.vercel.app

# Optional: AI model for agents (default: gpt-4o-mini)
# AI_MODEL=gpt-4o-mini

# Optional: Max tool-calling iterations per agent run (default: 8)
# AGENT_MAX_ITERATIONS=8

# Optional: Default daily notification time in UTC (default: 08:00)
# DAILY_NOTIFY_HOUR=8
# DAILY_NOTIFY_MINUTE=0

# Optional: Alert check interval in minutes (default: 5)
# ALERT_CHECK_INTERVAL=5

# Optional: ChromaDB persist directory (default: data/chromadb)
# CHROMA_PERSIST_DIR=data/chromadb

# Optional: Short-term memory TTL in days (default: 7)
# MEMORY_SHORT_TERM_TTL_DAYS=7

# Optional: Number of memory entries to retrieve per recall (default: 5)
# MEMORY_RECALL_LIMIT=5

# Optional: Embedding model for memory (default: text-embedding-3-small)
# Uses OpenAI embeddings if OPENAI_API_KEY is set, otherwise local model
# EMBEDDING_MODEL=text-embedding-3-small
